ELASTICSEARCH_URL=https://user_name:password@test.bonsaisearch.net
DEFAULT_INDEX=restaurants
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
ENABLE_STRUCTURED_LOGGING=true
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
ALLOW_DEBUG_SLEEP=false
DEBUG_SLEEP_HEADER=x-debug-sleep-token
DEBUG_SLEEP_SECRET=change-me
MAX_DEBUG_SLEEP_MS=5000
REQUEST_BODY_LIMIT=1048576
REQUEST_TIMEOUT_MS=30000
OPENSEARCH_REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
